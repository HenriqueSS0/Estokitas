# Variáveis de ambiente — Docker Stack
# ATENÇÃO: COPIE ESTE ARQUIVO PARA `.env` E PREENCHA TODOS OS VALORES

# Backend / Node
NODE_ENV=production
PORT=3001

# Banco de Dados
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=estokitas
POSTGRES_USER=estokitas
POSTGRES_PASSWORD= # PREENCHA AQUI - SENHA DO BANCO DE DADOS

# JWT
JWT_SECRET= # PREENCHA AQUI - CHAVE SUPER SECRETA PARA O JWT (mínimo 32 caracteres)

# Criptografia das API Keys
ENCRYPTION_KEY= # PREENCHA AQUI - CHAVE DE CRIPTOGRAFIA EXATAMENTE 32 CARACTERES

# URL do frontend (para CORS no backend)
FRONTEND_URL=http://localhost:80

# URL da API (usada no build do frontend)
VITE_API_URL=/api

# SMTP (Configuração de e-mail - Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@estokitas.com
